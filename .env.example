NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3003
AUTH_URL=http://localhost:3003

# Shared MEAVO Neon (same database as gateway, sales, MRP — pooled connection)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — Web application client
# Redirect URIs: http://localhost:3003/api/auth/callback/google
#                 https://rp.meavo.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Gateway tool card id (register seed-rp-tool in meavo-gateway)
MEAVO_APP_KEY=rp
RP_TOOL_CARD_ID=seed-rp-tool
GATEWAY_URL=https://meavo.app

# Rep.Parts26 backup sheet (service account must have access)
REP_PARTS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
REP_PARTS_SHEET_NAME=Rep.Parts26
INTERNAL_PRODUCTION_SHEET_NAME=Internal Production

# Vercel Cron bearer token (optional in local dev)
CRON_SECRET=

SLACK_BOT_TOKEN=

# Channel IDs (from legacy GAS RPSlackBot.js)
SLACK_URGENT_CHANNEL=C0B2MLZRP2T
SLACK_RP_CHANNEL=C0B2MLZRP2T
SLACK_KAZ_PANEL_CHANNEL=
SLACK_VAR_PANEL_CHANNEL=
SLACK_LOGISTICS_CHANNEL=C0B36PBQQP6

# Export automation source sheets (legacy ExportAutomation.js defaults)
IZNOS_SPREADSHEET_ID=1ek1j6DFfTd4BfdI1MiPQedg0jr-V1VoYKHTpXW4DaKs
FREIGHT_SPREADSHEET_ID=1Gfgi6N2fuilpXLcTuqt49tEskoMjF4A0d1eic8Hc7b8

# Emergency kill-switch: all webapp automations no-op (ignores admin settings)
RP_NOTIFICATIONS_FORCE_OFF=

# Kill-switch: Neon → Google Sheet backup (sheet-sync cron + enqueue) no-op
RP_SHEET_SYNC_FORCE_OFF=

BLOB_READ_WRITE_TOKEN=
